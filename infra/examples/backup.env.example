BACKUP_DIR=/var/backups/wasm-pdf-editor/postgres
BACKUP_RETENTION_DAYS=14
BACKUP_AGE_RECIPIENT_FILE=/etc/wasm-pdf-editor/backup.age-recipient
BACKUP_REQUIRE_OFFSITE=true
BACKUP_S3_URI=s3://replace-with-production-backup-bucket/postgres
BACKUP_S3_ENDPOINT=https://replace-with-account-id.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=replace-with-prefix-scoped-key-id
AWS_SECRET_ACCESS_KEY=replace-with-prefix-scoped-secret
AWS_DEFAULT_REGION=auto
