PUBLIC_DOMAIN=pdf.example.com
POSTGRES_DB=pdf_editor
POSTGRES_USER=pdf_editor
DATABASE_RUNTIME_USER=pdf_editor_runtime
DATABASE_MAX_CONNECTIONS=10
AUDIT_RETENTION_DAYS=365
SESSION_RETENTION_DAYS=30
MAINTENANCE_INTERVAL_SECONDS=21600
SECRETS_DIR=/etc/wasm-pdf-editor/secrets
SMTP_HOST=smtp.provider.example
SMTP_PORT=587
SMTP_USERNAME=provider-account
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_NAME='PDF Editor'
GRAFANA_PORT=3000
DEPLOY_REQUIRE_BACKUP=true
DEPLOY_HEALTH_ATTEMPTS=30
DEPLOY_HEALTH_INTERVAL_SECONDS=5
DEPLOY_KEEP_RELEASES=5
