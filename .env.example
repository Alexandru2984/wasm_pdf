HTTP_PORT=8080
APP_ENV=development
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
RUST_LOG=backend=info
POSTGRES_DB=pdf_editor
POSTGRES_USER=pdf_editor
POSTGRES_PASSWORD=change-me
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=pdf_editor
DATABASE_USER=pdf_editor
DATABASE_MAX_CONNECTIONS=10
RUN_MIGRATIONS=true
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ISSUER=wasm-pdf-editor
JWT_AUDIENCE=wasm-pdf-editor-web
ACCESS_TOKEN_SECONDS=900
SESSION_DAYS=30
# Set true behind production HTTPS. Plain local HTTP requires false.
COOKIE_SECURE=false
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:8080
WEBAUTHN_RP_NAME=PDF Editor
